# Node Environment
NODE_ENV=development

# TiDB / MySQL Configuration (Put your actual credentials in a local .env file)
DB_HOST=your-tidb-host
DB_PORT=4000
DB_USER=your-tidb-username
DB_PASS=your-tidb-password
DB_NAME=your-database-name

# Admin Session Security
SESSION_SECRET=super-secret-random-long-string-for-sessions